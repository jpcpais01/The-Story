rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /world/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /galaxy/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /locations/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /civilizations/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Everything else is denied by default.
  }
}
